# Financial Intelligence Engine environment example

# Local by default. Use "cloud" later when deployed.
FIE_ENV=local

# GenAI provider:
# local  -> deterministic/local fallback
# openai -> OpenAI Responses API provider
FIE_GENAI_PROVIDER=local

# Set this to openai only when OPENAI_API_KEY is configured:
# FIE_GENAI_PROVIDER=openai

# OpenAI model to use when FIE_GENAI_PROVIDER=openai.
FIE_GENAI_MODEL=gpt-5.4-mini

# Never commit your real key.
OPENAI_API_KEY="replace_with_your_key"

# Required only when downloading SEC EDGAR filings.
# SEC asks automated clients to identify the application and a contact email.
FIE_SEC_USER_AGENT="FinancialIntelligenceEngine/1.0 your_email@example.com"

# Optional custom data root.
# FIE_DATA_ROOT=C:\SumeetFiles\Finance_project\financial_intelligence_engine\data

# Cloud server configuration.
# FIE_HOST=0.0.0.0
# PORT=10000
# FIE_MODEL_DIR=/var/data/models
# FIE_REPORTS_DIR=/var/data/reports
